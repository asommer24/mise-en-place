# Mise en Place — Environment Variables
# Copy to .env for local dev; add each as a GitHub Secret for production

# =============================================================
# REQUIRED
# =============================================================
ANTHROPIC_API_KEY=sk-ant-...

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Ingest endpoint — shared secret guarding POST /ingest.
# Generate any long random string; set the same value here and in the
# frontend's VITE_INGEST_TOKEN (and your iOS Shortcut).
INGEST_TOKEN=change-me-to-a-long-random-string

# =============================================================
# FRONTEND (Vite) — set these in the web app's environment, NOT here
# =============================================================
# VITE_INGEST_URL=https://your-ingest-service.railway.app
# VITE_INGEST_TOKEN=<same value as INGEST_TOKEN above>
#
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...   # the ANON / "publishable" key — NOT service_role
#
# Note: VITE_* vars are bundled into the client and visible to anyone who loads
# the site. That is fine for these specific values:
#   - VITE_INGEST_TOKEN is anti-spam, not a real secret.
#   - VITE_SUPABASE_ANON_KEY is the public key. Under our RLS (scripts/schema.sql)
#     it can read recipes + plans and update the CURRENT/future week's plan only.
#     It is NOT a write-anything credential, but anyone with it CAN edit this
#     week's plan — acceptable for a private 2-person app, and recoverable since
#     the agents regenerate plans weekly.
# NEVER put SUPABASE_SERVICE_KEY in a VITE_* var — it bypasses RLS entirely.

# =============================================================
# SHOPPING LIST BACKEND — choose one
# =============================================================

# Option A: Apple Reminders (CalDAV)
SHOPPING_BACKEND=apple
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=you@icloud.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx   # app-specific password from appleid.apple.com
REMINDERS_LIST_NAME=Grocery List       # create this list in Reminders.app first

# Option B: Todoist
# SHOPPING_BACKEND=todoist
# TODOIST_API_KEY=...
# TODOIST_PROJECT_NAME=Groceries

# =============================================================
# OPTIONAL
# =============================================================

# Instagram scraper (RapidAPI) — improves IG link parsing
# INSTAGRAM_SCRAPER_API_KEY=...
