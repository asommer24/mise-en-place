# Mise en Place — Environment Variables
# Copy to .env for local dev; add each as a GitHub Secret for production

# =============================================================
# REQUIRED
# =============================================================
ANTHROPIC_API_KEY=sk-ant-...

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Twilio — SMS sending
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX    # your Twilio number

# Recipients
PHONE_NUMBER_1=+1XXXXXXXXXX
PHONE_NUMBER_2=+1XXXXXXXXXX

# Your deployed frontend
APP_URL=https://your-app.vercel.app

# =============================================================
# SHOPPING LIST BACKEND — choose one
# =============================================================

# Option A: Apple Reminders (CalDAV)
SHOPPING_BACKEND=apple
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=you@icloud.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx   # app-specific password from appleid.apple.com
REMINDERS_LIST_NAME=Grocery List       # create this list in Reminders.app first

# Option B: Todoist
# SHOPPING_BACKEND=todoist
# TODOIST_API_KEY=...
# TODOIST_PROJECT_NAME=Groceries

# =============================================================
# OPTIONAL
# =============================================================

# Instagram scraper (RapidAPI) — improves IG link parsing
# INSTAGRAM_SCRAPER_API_KEY=...
